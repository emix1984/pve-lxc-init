# pve-lxc-init 配置文件 - 複製此檔案為 /etc/default/pve-lxc-init 並修改
# cp .env.sample /etc/default/pve-lxc-init
# chmod 600 /etc/default/pve-lxc-init

# 伺服器名稱（用於 Gotify 推送時辨識）
DEVICE_NAME="my-server"

# Gotify 服務端點與 Token
GOTIFY_URL="https://gotify.example.com"
GOTIFY_TOKEN="your-gotify-app-token-here"

# Tailscale Peer IP（監控 Agent 用來檢測連通性，無 Tailscale 可留空）
TARGET_PEER_IP="100.114.252.115"
